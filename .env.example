# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# CONTRACT_ADDRESS: The address of the deployed OnchainArcade contract on Base.
NEXT_PUBLIC_CONTRACT_ADDRESS="0x..."

# POWER_UP_NFT_ADDRESS: The address of the deployed ConsumableItems (ERC-1155) contract.
# Deploy with: npx hardhat compile && node scripts/deploy-consumables.mjs
NEXT_PUBLIC_POWER_UP_NFT_ADDRESS="0x..."

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# DEPLOYER_PRIVATE_KEY: Private key for Hardhat contract deployment.
# WARNING: Never commit the real key. Used only by scripts/deploy.mjs.
DEPLOYER_PRIVATE_KEY="0x..."

# PAYMASTER_URL: CDP Paymaster for gas-sponsored Sub Account transactions.
# Create at https://portal.cdp.coinbase.com — allowlist ConsumableItems + useAndBurn only.
NEXT_PUBLIC_PAYMASTER_URL="https://api.developer.coinbase.com/rpc/v1/base-sepolia/YOUR_CDP_KEY"
